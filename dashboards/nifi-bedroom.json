{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "nifi-bedroom",
  "title": "NiFi — Bedroom",
  "tags": ["nifi", "bedroom", "infrastructure"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "NiFi Health",
      "type": "row"
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Status",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_up{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }] } }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "JVM Heap",
      "gridPos": { "h": 4, "w": 4, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_jvm_heap_utilization_percent{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 85, "color": "red" }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Running",
      "gridPos": { "h": 4, "w": 3, "x": 7, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_processors_running{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Stopped",
      "gridPos": { "h": 4, "w": 3, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_processors_stopped{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "yellow" }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Invalid",
      "gridPos": { "h": 4, "w": 3, "x": 13, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_processors_invalid{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Queued",
      "gridPos": { "h": 4, "w": 3, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_flow_flowfiles_queued{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 100, "color": "yellow" }, { "value": 1000, "color": "red" }] } } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Active Threads",
      "gridPos": { "h": 4, "w": 3, "x": 19, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nifi_flow_active_threads{job=\"nifi\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Throughput",
      "type": "row"
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "FlowFiles In / Out (5 min window)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nifi_flow_flowfiles_in{job=\"nifi\"}", "legendFormat": "In", "refId": "A" },
        { "expr": "nifi_flow_flowfiles_out{job=\"nifi\"}", "legendFormat": "Out", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Bytes In / Out (5 min window)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nifi_flow_bytes_in{job=\"nifi\"}", "legendFormat": "In", "refId": "A" },
        { "expr": "nifi_flow_bytes_out{job=\"nifi\"}", "legendFormat": "Out", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "JVM Resources",
      "type": "row"
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "JVM Heap Memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nifi_jvm_heap_used_bytes{job=\"nifi\"}", "legendFormat": "Used", "refId": "A" },
        { "expr": "nifi_jvm_heap_max_bytes{job=\"nifi\"}", "legendFormat": "Max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nifi_flow_flowfiles_queued{job=\"nifi\"}", "legendFormat": "FlowFiles", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "NiFi Logs",
      "type": "row"
    },
    {
      "id": 30,
      "type": "logs",
      "title": "Application Log (ERROR + WARN)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{job=\"nifi\", component=\"app\"} |~ \"(?i)(error|warn)\"", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "id": 31,
      "type": "logs",
      "title": "Full Application Log",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{job=\"nifi\", component=\"app\"}", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
