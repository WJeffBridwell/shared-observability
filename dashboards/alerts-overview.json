{
  "uid": "alerts-overview",
  "title": "Alerts Overview",
  "description": "Consolidated alert view — firing, history, and trends",
  "tags": ["alerts", "operations"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"],
    "time_options": ["1h", "6h", "12h", "24h", "2d", "7d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Firing Now",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Clear", "color": "green" } } }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "id": 2,
      "title": "Critical",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\",severity=\"critical\"}) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "None", "color": "green" } } }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "id": 3,
      "title": "Warning",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\",severity=\"warning\"}) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "orange" }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "None", "color": "green" } } }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "id": 4,
      "title": "Total Rules",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (alertname)(ALERTS or ALERTS_FOR_STATE)) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["last"] }
      }
    },
    {
      "id": 10,
      "title": "",
      "type": "text",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### Alerts Overview\nAll infrastructure and application alerts in one view.\n\n**Time range** controls history depth.\n\n[Alert Rules](/alerting/list) · [Silences](/alerting/silences) · [Contact Points](/alerting/notifications)"
      }
    },
    {
      "id": 5,
      "title": "Currently Firing / Pending",
      "description": "All alerts in firing or pending state right now",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "ALERTS",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "Time": true,
              "instance": true,
              "job": true,
              "project": true,
              "service": true,
              "Value": true
            },
            "renameByName": {
              "alertname": "Alert",
              "severity": "Severity",
              "alertstate": "State",
              "query": "Query"
            },
            "indexByName": {
              "alertname": 0,
              "alertstate": 1,
              "severity": 2,
              "query": 3
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "All clear — no alerts firing or pending"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "text": "CRITICAL", "color": "red" }, "warning": { "text": "WARNING", "color": "yellow" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "firing": { "text": "FIRING", "color": "red" }, "pending": { "text": "PENDING", "color": "orange" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "State", "desc": true }]
      }
    },
    {
      "id": 6,
      "title": "Alert Timeline",
      "description": "Visual timeline — red = firing, green = normal. Drag time range to zoom.",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "ALERTS{alertstate=~\"firing|pending\"}",
          "refId": "A",
          "legendFormat": "{{alertname}} ({{query}}{{service}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": {
            "fillOpacity": 80
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "FIRING", "color": "red" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "OK", "color": "green" } } }
          ]
        }
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "left",
        "rowHeight": 0.8
      }
    },
    {
      "id": 7,
      "title": "Alert Count Over Time",
      "description": "Are we getting noisier or quieter?",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\",severity=\"critical\"}) or vector(0)",
          "refId": "A",
          "legendFormat": "Critical"
        },
        {
          "expr": "count(ALERTS{alertstate=\"firing\",severity=\"warning\"}) or vector(0)",
          "refId": "B",
          "legendFormat": "Warning"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "pointSize": 5,
            "lineWidth": 0
          },
          "color": { "mode": "fixed" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Warning" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "title": "Alert Events (Loki)",
      "description": "Alert firing and resolved events from alert-notifier",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "uid": "loki", "type": "loki" },
      "targets": [
        {
          "expr": "{job=\"chorus-operations\"} |~ \"alert_firing|alert_resolved\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
